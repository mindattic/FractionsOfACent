<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- LocalNuGet hosts MindAttic.Vault during the rollout. Once Vault is
         published to nuget.org this source can be removed. -->
    <add key="LocalNuGet" value="C:\LocalNuGet" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
